# --- App ---
APP_ENV=prod
LOG_LEVEL=INFO

# --- RocketMQ ---
ROCKETMQ_NAME_SERVER=rmq-namesrv:9876
ROCKETMQ_TOPIC=im_conv
ROCKETMQ_CONSUMER_GROUP=chatbot_conv_consumer
ROCKETMQ_SUBSCRIPTION_EXPRESSION=*

# --- Redis / MySQL ---
REDIS_URL=redis://redis:6379/0
MYSQL_DSN=mysql+asyncmy://root:root@mysql:3306/violet?charset=utf8mb4

# --- IMService gRPC ---
ACTION_GRPC_TARGET=action:3003
IM_GRPC_TARGET=im:3004
AIGC_GRPC_TARGET=aigc:3005

# --- Window policy ---
WINDOW_BASE_MS=5000
WINDOW_MAX_MS=10000

# --- Two-bot gap policy ---
SECOND_GAP_MIN_MS=3000
SECOND_GAP_MAX_MS=8000

# --- Group rate limit (token bucket) ---
GROUP_BUCKET_CAP=3
GROUP_BUCKET_PERIOD_MS=300000

# --- bot↔bot strict token ---
BOT2BOT_TOKEN_TTL_SEC=600

# --- Scheduler worker ---
SCHEDULER_POLL_INTERVAL_MS=200
SCHEDULER_BATCH_SIZE=64

# DashScope API Key
DASHSCOPE_API_KEY=xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus
QWEN_TEMPERATURE=0.7
QWEN_TIMEOUT_SEC=30

# Web Search
BOCHA_API_KEY=xxx
WEB_SEARCH_BASE_URL=https://api.bochaai.com/v1/web-search
WEB_SEARCH_TIMEOUT_SEC=20
WEB_SEARCH_MAX_CHARS=10000
WEB_SEARCH_DEFAULT_COUNT=10
WEB_SEARCH_DEFAULT_FRESHNESS=noLimit
WEB_SEARCH_DEFAULT_SUMMARY=true